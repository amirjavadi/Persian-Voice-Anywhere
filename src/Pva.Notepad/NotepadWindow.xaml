<Window x:Class="Pva.Notepad.NotepadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Pva.Notepad"
        Title="نوت‌پد — Persian Voice Anywhere"
        Height="580" Width="800" WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft" FontFamily="{DynamicResource AppFontFamily}"
        Background="{DynamicResource PvaBgBrush}" Foreground="{DynamicResource PvaTextBrush}">
    <Window.Resources>
        <local:BoolToTextWrappingConverter x:Key="WrapConverter"/>
        <local:BoolToFlowDirectionConverter x:Key="FlowConverter"/>
    </Window.Resources>

    <!-- میانبرهای صفحه‌کلید -->
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="N" Command="{Binding NewCommand}"/>
        <KeyBinding Modifiers="Control" Key="T" Command="{Binding NewCommand}"/>
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenCommand}"/>
        <KeyBinding Modifiers="Control" Key="S" Command="{Binding SaveCommand}"/>
        <KeyBinding Modifiers="Control+Shift" Key="S" Command="{Binding SaveAsCommand}"/>
        <KeyBinding Modifiers="Control" Key="W" Command="{Binding CloseTabCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- نوار ابزار شیشه‌ای -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource PvaSurfaceBrush}"
                BorderBrush="{DynamicResource PvaBorderBrush}" BorderThickness="0,0,0,1" Padding="10,7">
            <StackPanel Orientation="Horizontal">
                <Border Width="4" Height="20" CornerRadius="2" Background="{DynamicResource PvaAccentGradient}"
                        VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Content="جدید" Command="{Binding NewCommand}" Style="{DynamicResource PvaGhostButton}"
                        ToolTip="سند جدید (Ctrl+N)" Margin="1,0"/>
                <Button Content="باز کردن" Command="{Binding OpenCommand}" Style="{DynamicResource PvaGhostButton}"
                        ToolTip="باز کردن (Ctrl+O)" Margin="1,0"/>
                <Button Content="ذخیره" Command="{Binding SaveCommand}" Style="{DynamicResource PvaGhostButton}"
                        ToolTip="ذخیره (Ctrl+S)" Margin="1,0"/>
                <Button Content="ذخیره به‌نام" Command="{Binding SaveAsCommand}" Style="{DynamicResource PvaGhostButton}"
                        ToolTip="ذخیره به‌نام (Ctrl+Shift+S)" Margin="1,0"/>
                <Border Width="1" Height="20" Background="{DynamicResource PvaBorderBrush}" Margin="8,0"/>
                <Button Content="بستن تب" Command="{Binding CloseTabCommand}" Style="{DynamicResource PvaGhostButton}"
                        ToolTip="بستن تب (Ctrl+W)" Margin="1,0"/>
                <Border Width="1" Height="20" Background="{DynamicResource PvaBorderBrush}" Margin="8,0"/>
                <ToggleButton Content="شکستن خط" IsChecked="{Binding WordWrap}"
                              Style="{DynamicResource PvaToggleButton}" ToolTip="Word Wrap" Margin="1,0"/>
                <Button Content="تغییر جهت" Command="{Binding ToggleDirectionCommand}"
                        Style="{DynamicResource PvaGhostButton}" ToolTip="راست‌به‌چپ / چپ‌به‌راست" Margin="1,0"/>
            </StackPanel>
        </Border>

        <!-- نوار وضعیت -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource PvaSurfaceBrush}"
                BorderBrush="{DynamicResource PvaBorderBrush}" BorderThickness="0,1,0,0" Padding="12,5">
            <Grid>
                <TextBlock HorizontalAlignment="Left" Foreground="{DynamicResource PvaTextMutedBrush}" FontSize="11"
                           Text="{Binding StatusMessage}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Foreground="{DynamicResource PvaTextMutedBrush}" FontSize="11"
                               Text="{Binding ActiveDocument.WordCount, StringFormat='واژه: {0}'}"/>
                    <TextBlock Foreground="{DynamicResource PvaBorderBrush}" FontSize="11" Margin="10,0" Text="|"/>
                    <TextBlock Foreground="{DynamicResource PvaTextMutedBrush}" FontSize="11"
                               Text="{Binding ActiveDocument.CharCount, StringFormat='نویسه: {0}'}"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl ItemsSource="{Binding Documents}" SelectedItem="{Binding ActiveDocument}"
                    Background="Transparent" BorderThickness="0" Padding="0" Margin="8,6,8,0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="{DynamicResource PvaTextMutedBrush}"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="3"/>
                                    </Grid.RowDefinitions>
                                    <Border x:Name="Bd" Grid.Row="0" CornerRadius="8,8,0,0"
                                            Background="Transparent" Padding="12,7">
                                        <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                                    </Border>
                                    <Border x:Name="Underline" Grid.Row="1" Height="3" CornerRadius="2"
                                            Background="{DynamicResource PvaAccentGradient}" Opacity="0" Margin="6,0"/>
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#14FFFFFF"/>
                                        <Setter TargetName="Underline" Property="Opacity" Value="1"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PvaTextBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.ItemContainerStyle>
            <TabControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding TabHeader}" VerticalAlignment="Center"/>
                        <Button Content="✕" Margin="8,0,0,0" Padding="4,0" FontSize="10"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{DynamicResource PvaTextMutedBrush}"
                                Cursor="Hand" ToolTip="بستن این تب"
                                Command="{Binding DataContext.CloseTabCommand,
                                    RelativeSource={RelativeSource AncestorType=TabControl}}"
                                CommandParameter="{Binding}"/>
                    </StackPanel>
                </DataTemplate>
            </TabControl.ItemTemplate>
            <TabControl.ContentTemplate>
                <DataTemplate>
                    <Border Background="{DynamicResource PvaSurfaceBrush}" CornerRadius="12,12,0,0"
                            BorderBrush="{DynamicResource PvaBorderBrush}" BorderThickness="1,1,1,0" Margin="0,4,0,0">
                        <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" AcceptsTab="True"
                                 TextWrapping="{Binding DataContext.WordWrap,
                                     RelativeSource={RelativeSource AncestorType=Window},
                                     Converter={StaticResource WrapConverter}}"
                                 FlowDirection="{Binding IsRightToLeft, Converter={StaticResource FlowConverter}}"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 Background="Transparent" Foreground="{DynamicResource PvaTextBrush}"
                                 CaretBrush="{DynamicResource PvaAccentBrush}"
                                 SelectionBrush="{DynamicResource PvaAccentBrush}"
                                 BorderThickness="0"
                                 FontFamily="{DynamicResource AppFontFamily}" FontSize="15" Padding="16"
                                 SpellCheck.IsEnabled="False" />
                    </Border>
                </DataTemplate>
            </TabControl.ContentTemplate>
        </TabControl>
    </DockPanel>
</Window>
