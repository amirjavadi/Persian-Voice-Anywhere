<Window x:Class="Pva.StickyNotes.StickyNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="یادداشت" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" FlowDirection="RightToLeft" FontFamily="Segoe UI, Tahoma"
        Left="{Binding Left, Mode=TwoWay}" Top="{Binding Top, Mode=TwoWay}"
        Width="{Binding Width, Mode=TwoWay}" Height="{Binding Height, Mode=TwoWay}"
        Topmost="{Binding Pinned}" MinWidth="180" MinHeight="150">
    <Border CornerRadius="14" Background="#F21C1D22" BorderBrush="#26FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.45" Color="#000000"/>
        </Border.Effect>
        <DockPanel Margin="2">
            <Grid DockPanel.Dock="Top" Height="32" Background="Transparent"
                  MouseLeftButtonDown="OnDragWindow">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="6,0">
                    <ToggleButton x:Name="PinButton" Content="📌" IsChecked="{Binding Pinned}"
                                  Background="Transparent" BorderThickness="0" Foreground="#FAFAFA"
                                  ToolTip="پین روی همه‌ی پنجره‌ها" Width="26"/>
                    <Button Content="✕" Click="OnDelete" Background="Transparent" BorderThickness="0"
                            Foreground="#C0FAFAFA" Width="26" ToolTip="حذف یادداشت"/>
                </StackPanel>
            </Grid>
            <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" Background="Transparent"
                     Foreground="#FAFAFA" BorderThickness="0" FontSize="14" Padding="10"
                     VerticalScrollBarVisibility="Auto" SpellCheck.IsEnabled="False"/>
        </DockPanel>
    </Border>
</Window>
