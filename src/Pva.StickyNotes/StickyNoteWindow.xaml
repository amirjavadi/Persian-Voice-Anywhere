<Window x:Class="Pva.StickyNotes.StickyNoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="یادداشت" WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" FlowDirection="RightToLeft" FontFamily="{DynamicResource AppFontFamily}"
        Left="{Binding Left, Mode=TwoWay}" Top="{Binding Top, Mode=TwoWay}"
        Width="{Binding Width, Mode=TwoWay}" Height="{Binding Height, Mode=TwoWay}"
        Topmost="{Binding Pinned}" MinWidth="180" MinHeight="150">
    <Border CornerRadius="16" Background="#F2161821" BorderBrush="#33FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <DockPanel Margin="2">
            <!-- نوار بالایی با رگه‌ی گرادیانی برند -->
            <Grid DockPanel.Dock="Top" Height="34" Background="Transparent"
                  MouseLeftButtonDown="OnDragWindow">
                <Border Height="3" VerticalAlignment="Top" Margin="14,6,14,0" CornerRadius="2"
                        Background="{DynamicResource PvaAccentGradient}" Opacity="0.85"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="6,8,0,0">
                    <ToggleButton x:Name="PinButton" Content="📌" IsChecked="{Binding Pinned}"
                                  Style="{DynamicResource PvaToggleButton}" Padding="5,2"
                                  ToolTip="پین روی همه‌ی پنجره‌ها"/>
                    <Button Content="✕" Click="OnDelete" Style="{DynamicResource PvaIconButton}"
                            ToolTip="حذف یادداشت"/>
                </StackPanel>
            </Grid>
            <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True" TextWrapping="Wrap" Background="Transparent"
                     Foreground="{DynamicResource PvaTextBrush}" BorderThickness="0" FontSize="14" Padding="12,6,12,12"
                     CaretBrush="{DynamicResource PvaAccentBrush}"
                     SelectionBrush="{DynamicResource PvaAccentBrush}"
                     VerticalScrollBarVisibility="Auto" SpellCheck.IsEnabled="False"/>
        </DockPanel>
    </Border>
</Window>
