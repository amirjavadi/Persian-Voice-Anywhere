<Window x:Class="Pva.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Pva.App"
        mc:Ignorable="d"
        Title="Persian Voice Anywhere" Height="360" Width="560"
        WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft">
    <Grid Margin="24">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="🎙️ Persian Voice Anywhere"
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="در هر نرم‌افزار ویندوز صحبت کن، متن فارسی همان‌جا تایپ می‌شود."
                       FontSize="13" Opacity="0.75" Margin="0,10,0,0"
                       TextWrapping="Wrap" TextAlignment="Center" />
            <TextBlock Text="اسکلت M0 — زیرساخت آماده است. UI کامل در M7 ساخته می‌شود."
                       FontSize="12" Opacity="0.5" Margin="0,20,0,0"
                       TextAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
