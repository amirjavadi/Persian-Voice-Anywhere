<Window x:Class="Pva.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تنظیمات — Persian Voice Anywhere"
        Height="440" Width="460" WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft" FontFamily="Segoe UI, Tahoma"
        Background="#0F1013" Foreground="#FAFAFA">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="تنظیمات" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="کلید میانبر" Opacity="0.7" Margin="0,0,0,4"/>
            <TextBox Text="{Binding HotkeyGesture, UpdateSourceTrigger=PropertyChanged}"
                     Background="#1B1C20" Foreground="#FAFAFA" BorderBrush="#33FFFFFF"
                     Padding="8" Margin="0,0,0,14"/>

            <CheckBox Content="حالت Push-to-Talk (نگه‌داشتن برای ضبط)" IsChecked="{Binding PushToTalk}" Margin="0,6" Foreground="#FAFAFA"/>
            <CheckBox Content="ترجیح Faster Whisper (در صورت نصب engine pack)" IsChecked="{Binding PreferFasterWhisper}" Margin="0,6" Foreground="#FAFAFA"/>
            <CheckBox Content="استفاده از GPU در صورت وجود" IsChecked="{Binding UseGpu}" Margin="0,6" Foreground="#FAFAFA"/>
            <CheckBox Content="اصلاح هوشمند فارسی (نیم‌فاصله و علائم)" IsChecked="{Binding SmartCorrection}" Margin="0,6" Foreground="#FAFAFA"/>
            <CheckBox Content="ارقام فارسی" IsChecked="{Binding UsePersianDigits}" Margin="0,6" Foreground="#FAFAFA"/>
            <CheckBox Content="فعال‌بودن دستورهای صوتی" IsChecked="{Binding CommandModeEnabled}" Margin="0,6" Foreground="#FAFAFA"/>

            <TextBlock Text="شفافیت میکروفون شناور" Opacity="0.7" Margin="0,14,0,4"/>
            <Slider Minimum="0.4" Maximum="1.0" Value="{Binding MicOpacity}"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,16,0,0">
            <Button Content="ذخیره" Command="{Binding SaveCommand}" Padding="18,8"
                    Background="#FAFAFA" Foreground="#0F1013" BorderThickness="0" Cursor="Hand"/>
            <TextBlock Text="ذخیره شد ✓" Foreground="#6EE7A8" VerticalAlignment="Center"
                       Margin="12,0,0,0" Visibility="{Binding Saved, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>
    </Grid>
</Window>
