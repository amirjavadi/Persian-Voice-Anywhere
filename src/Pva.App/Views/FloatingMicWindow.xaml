<Window x:Class="Pva.App.Views.FloatingMicWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Persian Voice Anywhere"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft"
        FontFamily="{DynamicResource AppFontFamily}">
    <Window.Resources>
        <!-- تنفس گوی هنگام شنیدن -->
        <Storyboard x:Key="BreatheStoryboard">
            <DoubleAnimation Storyboard.TargetName="OrbScale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.05" Duration="0:0:1.2" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="OrbScale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.05" Duration="0:0:1.2" AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>
        <!-- halo ضربانی برند -->
        <Storyboard x:Key="HaloStoryboard">
            <DoubleAnimation Storyboard.TargetName="HaloScale" Storyboard.TargetProperty="ScaleX"
                             From="0.9" To="1.55" Duration="0:0:1.8" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="HaloScale" Storyboard.TargetProperty="ScaleY"
                             From="0.9" To="1.55" Duration="0:0:1.8" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Halo" Storyboard.TargetProperty="Opacity"
                             From="0.6" To="0" Duration="0:0:1.8" RepeatBehavior="Forever"/>
        </Storyboard>
        <!-- اکولایزر ۵ میله‌ای هنگام شنیدن -->
        <Storyboard x:Key="EqStoryboard">
            <DoubleAnimation Storyboard.TargetName="Eq1" Storyboard.TargetProperty="ScaleY"
                             From="0.25" To="1" Duration="0:0:0.42" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Eq2" Storyboard.TargetProperty="ScaleY"
                             From="0.9" To="0.3" Duration="0:0:0.36" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Eq3" Storyboard.TargetProperty="ScaleY"
                             From="0.35" To="1" Duration="0:0:0.5" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Eq4" Storyboard.TargetProperty="ScaleY"
                             From="1" To="0.4" Duration="0:0:0.33" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Eq5" Storyboard.TargetProperty="ScaleY"
                             From="0.3" To="0.85" Duration="0:0:0.45" AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>
    </Window.Resources>

    <!-- کارت شیشه‌ای Liquid Glass -->
    <Border x:Name="Root" Width="232" CornerRadius="22" Padding="18,20"
            Background="#F0101219" BorderBrush="#33FFFFFF" BorderThickness="1"
            MouseLeftButtonDown="OnRootMouseDown"
            MouseMove="OnRootMouseMove"
            MouseLeftButtonUp="OnRootMouseUp">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center">
            <Grid Width="112" Height="112">
                <!-- halo ضربانی فیروزه‌ای -->
                <Ellipse x:Name="Halo" Width="96" Height="96" Opacity="0"
                         Stroke="{DynamicResource PvaAccentBrush}" StrokeThickness="2"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="HaloScale"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- گوی گرادیانی برند با آیکون میکروفون -->
                <Border x:Name="Orb" Width="96" Height="96" CornerRadius="48" Cursor="Hand"
                        Background="{DynamicResource PvaOrbGradient}"
                        RenderTransformOrigin="0.5,0.5" MouseLeftButtonUp="OnOrbClick">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="OrbScale"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.55" Color="#13B9AC"/>
                    </Border.Effect>
                    <Grid>
                        <!-- برق شیشه‌ای بالای گوی -->
                        <Ellipse Width="70" Height="34" Margin="0,8,0,0" VerticalAlignment="Top" Opacity="0.35">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <Viewbox Width="38" Height="38">
                            <Canvas Width="24" Height="24">
                                <Border Canvas.Left="9" Canvas.Top="3" Width="6" Height="11" CornerRadius="3" Background="#FFFFFF"/>
                                <Path Stroke="#FFFFFF" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M6,12 A6,6 0 0 0 18,12 M12,18 L12,21"/>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Border>
            </Grid>

            <!-- اکولایزر: فقط هنگام شنیدن -->
            <StackPanel x:Name="Equalizer" Orientation="Horizontal" HorizontalAlignment="Center"
                        Height="22" Margin="0,12,0,0" Visibility="Collapsed">
                <StackPanel.Resources>
                    <Style TargetType="Rectangle">
                        <Setter Property="Width" Value="4"/>
                        <Setter Property="Height" Value="22"/>
                        <Setter Property="RadiusX" Value="2"/>
                        <Setter Property="RadiusY" Value="2"/>
                        <Setter Property="Margin" Value="3,0"/>
                        <Setter Property="Fill" Value="{DynamicResource PvaAccentGradient}"/>
                        <Setter Property="RenderTransformOrigin" Value="0.5,1"/>
                    </Style>
                </StackPanel.Resources>
                <Rectangle><Rectangle.RenderTransform><ScaleTransform x:Name="Eq1" ScaleY="0.3"/></Rectangle.RenderTransform></Rectangle>
                <Rectangle><Rectangle.RenderTransform><ScaleTransform x:Name="Eq2" ScaleY="0.8"/></Rectangle.RenderTransform></Rectangle>
                <Rectangle><Rectangle.RenderTransform><ScaleTransform x:Name="Eq3" ScaleY="0.5"/></Rectangle.RenderTransform></Rectangle>
                <Rectangle><Rectangle.RenderTransform><ScaleTransform x:Name="Eq4" ScaleY="1"/></Rectangle.RenderTransform></Rectangle>
                <Rectangle><Rectangle.RenderTransform><ScaleTransform x:Name="Eq5" ScaleY="0.4"/></Rectangle.RenderTransform></Rectangle>
            </StackPanel>

            <!-- pill وضعیت -->
            <Border CornerRadius="20" Background="#1AFFFFFF" Padding="12,5" Margin="0,12,0,0"
                    HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StateDot" Width="8" Height="8" VerticalAlignment="Center"
                             Fill="#6B7080" Margin="0,0,7,0"/>
                    <TextBlock Text="{Binding StateText}" Foreground="{DynamicResource PvaTextBrush}"
                               FontSize="12.5" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- راهنما: فقط وقتی در حال شنیدن نیست -->
            <TextBlock Text="برای شروع ضربه بزن — یا Ctrl+Space" Foreground="{DynamicResource PvaTextMutedBrush}"
                       FontSize="10.5" Margin="0,7,0,0" HorizontalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsListening}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- پیش‌نمایش آخرین رونویسی -->
            <TextBlock Text="{Binding LastTranscription}" Foreground="{DynamicResource PvaTextMutedBrush}"
                       FontSize="11" Margin="0,9,0,0" MaxWidth="190" MaxHeight="34"
                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                       HorizontalAlignment="Center" TextAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LastTranscription}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- چیپ خطا -->
            <Border CornerRadius="10" Background="#26FF7A85" Padding="10,6" Margin="0,9,0,0"
                    MaxWidth="196">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LastError}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding LastError}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding LastError}" Foreground="{DynamicResource PvaDangerBrush}"
                           FontSize="10.5" TextWrapping="Wrap" TextAlignment="Center"/>
            </Border>
        </StackPanel>
    </Border>
</Window>
