<Window x:Class="Pva.App.Views.FloatingMicWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Persian Voice Anywhere"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft"
        FontFamily="Segoe UI, Tahoma">
    <Window.Resources>
        <!-- تنفس نور گوی هنگام شنیدن -->
        <Storyboard x:Key="BreatheStoryboard">
            <DoubleAnimation Storyboard.TargetName="OrbScale" Storyboard.TargetProperty="ScaleX"
                             From="1" To="1.05" Duration="0:0:1.2" AutoReverse="True" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="OrbScale" Storyboard.TargetProperty="ScaleY"
                             From="1" To="1.05" Duration="0:0:1.2" AutoReverse="True" RepeatBehavior="Forever"/>
        </Storyboard>
        <!-- halo ضربانی -->
        <Storyboard x:Key="HaloStoryboard">
            <DoubleAnimation Storyboard.TargetName="HaloScale" Storyboard.TargetProperty="ScaleX"
                             From="0.9" To="1.5" Duration="0:0:2" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="HaloScale" Storyboard.TargetProperty="ScaleY"
                             From="0.9" To="1.5" Duration="0:0:2" RepeatBehavior="Forever"/>
            <DoubleAnimation Storyboard.TargetName="Halo" Storyboard.TargetProperty="Opacity"
                             From="0.55" To="0" Duration="0:0:2" RepeatBehavior="Forever"/>
        </Storyboard>
    </Window.Resources>

    <!-- سطح شیشه‌ی مونوکروم (Liquid Glass، نسخه‌ی WPF) -->
    <Border x:Name="Root" Width="210" CornerRadius="20" Padding="18"
            Background="#E8121214" BorderBrush="#26FFFFFF" BorderThickness="1"
            MouseLeftButtonDown="OnDragWindow">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center">
            <Grid Width="104" Height="104">
                <!-- halo ضربانی -->
                <Ellipse x:Name="Halo" Width="92" Height="92" Opacity="0"
                         Stroke="#FFFFFF" StrokeThickness="1.5" RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <ScaleTransform x:Name="HaloScale"/>
                    </Ellipse.RenderTransform>
                </Ellipse>

                <!-- گوی نور با آیکون وکتور میکروفون -->
                <Border x:Name="Orb" Width="92" Height="92" CornerRadius="46" Cursor="Hand"
                        RenderTransformOrigin="0.5,0.5" MouseLeftButtonUp="OnOrbClick">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="OrbScale"/>
                    </Border.RenderTransform>
                    <Border.Background>
                        <RadialGradientBrush GradientOrigin="0.35,0.3" Center="0.5,0.5" RadiusX="0.75" RadiusY="0.75">
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#DEDEE3" Offset="0.55"/>
                            <GradientStop Color="#ABABB4" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.35" Color="#000000"/>
                    </Border.Effect>
                    <Viewbox Width="36" Height="36">
                        <Canvas Width="24" Height="24">
                            <Border Canvas.Left="9" Canvas.Top="3" Width="6" Height="11" CornerRadius="3" Background="#17181D"/>
                            <Path Stroke="#17181D" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M6,12 A6,6 0 0 0 18,12 M12,18 L12,21"/>
                        </Canvas>
                    </Viewbox>
                </Border>
            </Grid>

            <TextBlock Text="{Binding StateText}" Foreground="#FAFAFA" FontSize="13"
                       FontWeight="SemiBold" Margin="0,14,0,0" HorizontalAlignment="Center"/>
            <TextBlock Text="برای شروع، ضربه بزن" Foreground="#8CFAFAFA" FontSize="11"
                       Margin="0,4,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
