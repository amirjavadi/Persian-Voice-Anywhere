<Window x:Class="Pva.App.Views.FloatingMicWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Persian Voice Anywhere"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen" FlowDirection="RightToLeft"
        FontFamily="Segoe UI, Tahoma">
    <!-- سطح شیشه‌ی مونوکروم (Liquid Glass، نسخه‌ی WPF خالص) -->
    <Border x:Name="Root" Width="210" CornerRadius="20" Padding="18"
            Background="#E8121214" BorderBrush="#26FFFFFF" BorderThickness="1"
            MouseLeftButtonDown="OnDragWindow">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <StackPanel HorizontalAlignment="Center">
            <Border Width="92" Height="92" CornerRadius="46" Cursor="Hand"
                    MouseLeftButtonUp="OnOrbClick">
                <Border.Background>
                    <RadialGradientBrush GradientOrigin="0.35,0.3" Center="0.5,0.5" RadiusX="0.75" RadiusY="0.75">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#D9D9DE" Offset="0.55"/>
                        <GradientStop Color="#A9A9B2" Offset="1"/>
                    </RadialGradientBrush>
                </Border.Background>
                <TextBlock Text="&#x1F3A4;" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="{Binding StateText}" Foreground="#FAFAFA" FontSize="13"
                       FontWeight="SemiBold" Margin="0,14,0,0" HorizontalAlignment="Center"/>
            <TextBlock Text="برای شروع، ضربه بزن" Foreground="#8CFAFAFA" FontSize="11"
                       Margin="0,4,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </Border>
</Window>
