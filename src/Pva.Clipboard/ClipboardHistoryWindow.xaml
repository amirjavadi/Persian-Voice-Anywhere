<Window x:Class="Pva.Clipboard.ClipboardHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تاریخچه‌ی کلیپ‌بورد — Persian Voice Anywhere"
        Height="520" Width="440" WindowStartupLocation="CenterScreen"
        FlowDirection="RightToLeft" FontFamily="Segoe UI, Tahoma"
        Background="#0F1013" Foreground="#FAFAFA">
    <DockPanel Margin="14">
        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Background="#1B1C20" Foreground="#FAFAFA" BorderBrush="#33FFFFFF" Padding="8"
                     VerticalContentAlignment="Center"/>
            <Button Grid.Column="1" Content="پاک‌سازی" Command="{Binding ClearUnpinnedCommand}"
                    Margin="8,0,0,0" Padding="12,6" Background="#1B1C20" Foreground="#FAFAFA" BorderThickness="0"/>
        </Grid>

        <ListBox ItemsSource="{Binding Results}" Background="Transparent" BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Margin" Value="0,3"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="#16171B" CornerRadius="10" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Text}" TextTrimming="CharacterEllipsis"
                                       MaxHeight="46" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="کپی" Padding="8,3" Margin="3,0" Background="#22FFFFFF"
                                        Foreground="#FAFAFA" BorderThickness="0"
                                        Command="{Binding DataContext.CopyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                                <ToggleButton Content="📌" IsChecked="{Binding Pinned, Mode=OneWay}" Width="28"
                                        Background="Transparent" BorderThickness="0" Foreground="#FAFAFA"
                                        Command="{Binding DataContext.PinCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                                <Button Content="✕" Width="26" Background="Transparent" Foreground="#C0FAFAFA"
                                        BorderThickness="0"
                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
